{
  "$schema": "https://json-schema.org/draft-07/schema",
  "$defs": {
    "record": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "thumbnail": {
          "type": "string"
        }
      },
      "required": ["name", "thumbnail"]
    }
  },
  "title": "DisplayGame config schema",
  "type": "object",
  "properties": {
    "patterns": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "pattern": ".*\\(.+\\).*"
      }
    },
    "records": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/record"
      }
    }
  }
}
